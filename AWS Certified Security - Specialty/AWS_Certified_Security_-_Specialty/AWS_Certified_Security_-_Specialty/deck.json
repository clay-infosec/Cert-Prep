    "notes": [
        {
            "__type__": "Note",
            "fields": [
                "STS",
                "A web service that grants users temporary, limited-privileges to access your AWS resource"
            ],
            "guid": "xh<:L4ScvS",
            "note_model_uuid": "5fcbb45c-6a48-11f1-b3c2-1e4652aeb480",
            "tags": []
        },
        {
            "__type__": "Note",
            "fields": [
                "SCP",
                "Service control policy.&nbsp;Organizational-level guardrails that centrally control the maximum available permissions for all accounts in your AWS Organization"
            ],
            "guid": "zkK?!lLsa#",
            "note_model_uuid": "5fcbb45c-6a48-11f1-b3c2-1e4652aeb480",
            "tags": []
        },
        {
            "__type__": "Note",
            "fields": [
                "This offers central control over the maximum \navailable permissions for IAM users and IAM roles in an organization.",
                "SCPs"
            ],
            "guid": "torB3t;(nK",
            "note_model_uuid": "5fcbb45c-6a48-11f1-b3c2-1e4652aeb480",
            "tags": []
        },
        {
            "__type__": "Note",
            "fields": [
                "Example SCP",
                "{<br>&nbsp; \"Version\": \"2012-10-17\",<br>&nbsp; \"Statement\": [<br>&nbsp;&nbsp;&nbsp; {<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \"Sid\": \"RequireMicroInstanceType\",<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \"Effect\": \"Deny\",<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \"Action\": \"ec2:RunInstances\",<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \"Resource\": [<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \"arn:aws:ec2:*:*:instance/*\"<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; ],<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \"Condition\": {<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \"StringNotEquals\": {<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \"ec2:InstanceType\": [<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \"t3.micro\",<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \"t2.micro\"<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; ]<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; }<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; }<br>&nbsp;&nbsp;&nbsp; }<br>&nbsp; ]<br>}"
            ],
            "guid": "t;>E+=7C=B",
            "note_model_uuid": "5fcbb45c-6a48-11f1-b3c2-1e4652aeb480",
            "tags": []
        },
        {
            "__type__": "Note",
            "fields": [
                "True or False: SCPs are only applied to Member accounts",
                "True"
            ],
            "guid": "lKub2q^8.}",
